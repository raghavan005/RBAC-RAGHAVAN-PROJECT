# ── Server ─────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development           # development | production | test

# ── Database ───────────────────────────────────────────────────────────────────
# MongoDB Atlas (recommended):
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/companydb?retryWrites=true&w=majority

# Local MongoDB alternative:
# MONGODB_URI=mongodb://localhost:27017/companydb

# ── JWT ────────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-with-64-char-random-hex-string
JWT_REFRESH_SECRET=replace-with-different-64-char-random-hex-string

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (no trailing slash)
ALLOWED_ORIGINS=http://localhost:3000
# Production example:
# ALLOWED_ORIGINS=https://your-app.vercel.app,https://www.yourdomain.com
